msgid "Ignore Existing Ordered Qty"
msgstr "기존 주문 수량 무시"

#: erpnext/manufacturing/doctype/production_plan/production_plan.py:1831
msgid "Ignore Existing Projected Quantity"
msgstr "기존 예상 수량 무시"

